# ─── PagerDuty ───────────────────────────────────────────────────────────────

# API key — generate at https://your-account.pagerduty.com/api_keys
PAGERDUTY_API_KEY=

# Email address of the PagerDuty user associated with the API key above.
# Required by the PagerDuty API when creating incidents (used as the From header).
PAGERDUTY_FROM_EMAIL=

# ─── OpsGenie ────────────────────────────────────────────────────────────────

# API key — generate at https://app.opsgenie.com/settings/api-key-management
OPSGENIE_API_KEY=

# ─── MongoDB ─────────────────────────────────────────────────────────────────

# Connection string for the local MongoDB instance (started via docker compose).
# Change this if using a remote or authenticated instance.
MONGODB_URI=mongodb://localhost:27017
